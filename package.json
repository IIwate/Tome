{
  "name": "tome",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "type-check": "tsc --noEmit --incremental -p tsconfig.check.json",
    "lint": "npm run type-check",
    "test:unit": "vitest run --passWithNoTests src/test/unit",
    "test:integration": "vitest run --passWithNoTests src/test/integration",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:smoke": "node scripts/test-smoke.cjs",
    "check:commit": "npm run lint",
    "check:push": "npm run type-check && npm run test:unit && npm run test:rust",
    "check:ci": "npm run lint && npm run type-check && npm run test:unit && npm run test:integration && npm run test:rust",
    "check:full": "npm run check:ci && npm run test:smoke",
    "prepare": "husky"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-store": "^2",
    "class-variance-authority": "^0.7",
    "clsx": "^2",
    "fflate": "^0.8.2",
    "foliate-js": "^1.0.1",
    "framer-motion": "^11",
    "lucide-react": "^0.468",
    "react": "^19",
    "react-dom": "^19",
    "tailwind-merge": "^2",
    "zustand": "^5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.2.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "autoprefixer": "^10",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "postcss": "^8",
    "tailwindcss": "^3",
    "tailwindcss-animate": "^1",
    "typescript": "~5.7",
    "vite": "^6",
    "vitest": "^4.0.18"
  }
}
